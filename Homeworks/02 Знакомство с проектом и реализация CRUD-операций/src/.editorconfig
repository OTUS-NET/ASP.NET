# Top-most EditorConfig file
root = true

# All files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]
#### Core Standards ####
# Использовать file-scoped namespaces (namespace MyProject;) вместо блоков {}
csharp_style_namespace_declarations = file_scoped:error

# Использовать var, когда тип очевиден
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion

#### Nullability ####
# Считать CS8618 (Non-nullable field uninitialized) ошибкой, а не предупреждением.
# Это заставит студентов использовать required или конструкторы.
dotnet_diagnostic.CS8618.severity = error

#### Formatting ####
# Новая строка перед { в методах, классах и т.д.
csharp_new_line_before_open_brace = all
# Пробелы внутри операторов
csharp_space_around_binary_operators = before_and_after

#### Naming Conventions ####
# Приватные поля с подчеркиванием (_camelCase)
dotnet_naming_rule.private_fields_with_underscore.symbols  = private_fields
dotnet_naming_rule.private_fields_with_underscore.style    = prefix_underscore
dotnet_naming_rule.private_fields_with_underscore.severity = suggestion

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.prefix_underscore.capitalization = camel_case
dotnet_naming_style.prefix_underscore.required_prefix = _
